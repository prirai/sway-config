width=800
lines=15
location=center
term=foot
prompt=Search an applicattion
allow_images=true
launcher-display-mode = "dmenu"
show-icons = true
icon-theme = "Papirus Dark"
prompt = Launch:
terminal = "foot"
cmd-terminal = "foot -e"

# Custom commands
menu-cmd-1 = "dolphin"
menu-cmd-2 = "nano"
menu-cmd-3 = "firefox"
menu-cmd-4 = "foot -e tmux"

# Custom labels
menu-label-1 = "File Manager (Dolphin)"
menu-label-2 = "Text Editor (Nano)"
menu-label-3 = "Web Browser (Firefox)"
menu-label-4 = "Terminal Multiplexer (tmux)"

# Keybindings
bind-key-1 = "1"
bind-key-2 = "2"
bind-key-3 = "3"
bind-key-4 = "4"

# Custom icons
menu-icon-1 = "system-file-manager"
menu-icon-2 = "accessories-text-editor"
menu-icon-3 = "web-browser"
menu-icon-4 = "utilities-terminal"