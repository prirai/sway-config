# Core settings
width = 800
lines = 15
location = center
term = alacritty
allow_markup = true
show = drun
launcher-display-mode = "dmenu"
allow_images=true
show-icons = true
icon-theme = "Chameleon"
prompt = "Launch application"
insensitive = true
hide_scroll = true

# Terminal commands (Zellij instead of tmux)
cmd-terminal = "alacritty -e zellij"
menu-cmd-4 = "alacritty -e zellij"

# Custom commands (updated labels)
menu-label-1 = "File Manager (Dolphin)"
menu-label-2 = "Text Editor (Nano)"
menu-label-3 = "Web Browser (Firefox)"
menu-label-4 = "Terminal Multiplexer (Zellij)"

# Keybindings
bind-key-1 = "1"
bind-key-2 = "2"
bind-key-3 = "3"
bind-key-4 = "4"

# Icons (using standard names)
menu-icon-1 = "system-file-manager"
menu-icon-2 = "accessories-text-editor"
menu-icon-3 = "web-browser"
menu-icon-4 = "utilities-terminal"
